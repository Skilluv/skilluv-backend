# Windows-local overrides — EXAMPLE ONLY.
#
# Copy this file to `.cargo/config.toml` on Windows to share OpenSSL discovery
# for `webauthn-rs` (which pulls `openssl-sys`). The active `config.toml` is
# gitignored because cargo `[env]` applies unconditionally (no OS guard), so a
# committed Windows path breaks Linux CI.

[env]
# FireDaemon OpenSSL 3.6 LTS — required because openssl-sys 0.9.x does not yet support OpenSSL 4.
# Layout is standard (include/, lib/), so a single OPENSSL_DIR is enough.
OPENSSL_DIR    = "C:\\Program Files\\FireDaemon OpenSSL 3"
OPENSSL_STATIC = "0"
