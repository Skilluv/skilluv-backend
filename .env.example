# Database
DATABASE_URL=postgres://skilluv:skilluv_secret@localhost:5433/skilluv

# Redis
REDIS_URL=redis://localhost:6379

# Server
HOST=0.0.0.0
PORT=3001

# Auth
JWT_SECRET=change-this-to-a-secure-random-string

# Enterprise B2B SSO — encryption key for at-rest IdP client_secret storage.
# 32 bytes base64. Generate with: `openssl rand -base64 32`.
# Required in production ; if omitted the SSO endpoints refuse to persist configs.
SSO_ENCRYPTION_KEY=

# URLs
BASE_URL=http://localhost:3001
JUDGE0_URL=http://localhost:2358

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=http://localhost:9004
MINIO_ACCESS_KEY=skilluv
MINIO_SECRET_KEY=skilluv_secret
MINIO_BUCKET=avatars

# CDN in front of MinIO avatars (Cloudflare, Bunny, etc.). Optional — when set,
# avatar URLs returned to the client use this base instead of the direct MinIO endpoint.
# AVATAR_CDN_BASE_URL=https://avatars.skilluv.com

# Email (Brevo)
# BREVO_API_KEY=xkeysib-your-api-key-here
EMAIL_FROM=noreply@skilluv.com
EMAIL_FROM_NAME=Skilluv

# Brevo webhook token (set in Brevo console under Transactional > Webhooks). Required for bounce handling.
# BREVO_WEBHOOK_TOKEN=long-random-string-shared-with-brevo

# Local SMTP (Mailpit) — takes priority over BREVO_API_KEY when set.
# Web UI: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=none
# SMTP_USER=
# SMTP_PASSWORD=

# GitHub OAuth (Phase 2 Sprint 5)
# GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
# GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_REDIRECT_URI=https://api.skilluv.com/api/auth/github/callback

# Stripe (Phase 3)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUCCESS_URL=https://skilluv.com/enterprise/credits/success?session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=https://skilluv.com/enterprise/credits/canceled
# STRIPE_PORTAL_RETURN_URL=https://skilluv.com/enterprise/credits

# OAuth login providers (Phase 3.1 + 3.2)
# GITHUB_LOGIN_REDIRECT_URI=https://api.skilluv.com/api/auth/github/login/callback
# GOOGLE_CLIENT_ID=xxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# GOOGLE_REDIRECT_URI=https://api.skilluv.com/api/auth/google/callback
# LINKEDIN_CLIENT_ID=xxxx
# LINKEDIN_CLIENT_SECRET=xxxx
# LINKEDIN_REDIRECT_URI=https://api.skilluv.com/api/auth/linkedin/callback

# Skilluv billing metadata (used in invoice HTML — Phase 3.10)
# SKILLUV_BILLING_ADDRESS="123 Rue Skilluv\n75001 Paris, France"
# SKILLUV_SIRET=000000000
# SKILLUV_VAT_NUMBER=FR00000000000

# Logging
RUST_LOG=skilluv_backend=debug,tower_http=debug

# Environment (dev | staging | prod). Used as Sentry "environment" tag.
ENVIRONMENT=dev

# Optional release identifier (defaults to crate version). Set to git SHA in CI for proper release tracking.
# RELEASE=abc1234

# Sentry / GlitchTip (self-hosted, API-compatible). Leave empty to disable error tracking.
# SENTRY_DSN=http://<key>@glitchtip.skilluv.com/1
# SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog product analytics (self-host preferred). Leave empty to disable.
# POSTHOG_HOST=https://posthog.skilluv.com
# POSTHOG_API_KEY=phc_xxx

# Metrics endpoint token. If set, GET /metrics requires Authorization: Bearer <token>.
# METRICS_TOKEN=long-random-string

# ─── Backup (skilluv-backup binary) ──────────────────────────────
# Required when running the `skilluv-backup` CLI. Not needed for the API server.
# BACKUP_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# BACKUP_R2_BUCKET=skilluv-backups
# BACKUP_R2_ACCESS_KEY=...
# BACKUP_R2_SECRET_KEY=...
# BACKUP_PREFIX=skilluv/postgres/
# BACKUP_TEMP_DIR=/var/tmp/skilluv-backup
# BACKUP_PG_DUMP=pg_dump
# BACKUP_PG_RESTORE=pg_restore
# BACKUP_PSQL=psql
# Optional notification webhook (Slack incoming webhook, Discord webhook, or any HTTP endpoint accepting JSON).
# BACKUP_NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/T0000/B0000/XXXX
# BACKUP_NOTIFY_KIND=slack    # slack | discord | generic

# MinIO mirror (for `skilluv-backup minio-mirror`). If unset, falls back to MINIO_* above.
# BACKUP_MINIO_SOURCE_ENDPOINT=http://localhost:9004
# BACKUP_MINIO_SOURCE_BUCKET=avatars
# BACKUP_MINIO_SOURCE_ACCESS_KEY=...
# BACKUP_MINIO_SOURCE_SECRET_KEY=...
# BACKUP_MINIO_SOURCE_REGION=us-east-1
# BACKUP_MINIO_PREFIX=skilluv/minio-avatars/
